# Normalise line endings
* text=auto

# Shell scripts HARUS tetap LF (akan rusak jika CRLF di Mac/Linux)
*.sh text eol=lf

# Batch files pakai CRLF (Windows)
*.bat text eol=crlf

# PHP, views, config — biarkan auto
*.php text=auto
*.html text=auto
*.css text=auto
*.js text=auto
*.json text=auto
*.md text=auto

# Binary — jangan di-touch
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
